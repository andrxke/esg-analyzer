# Secrets — never commit keys. Use env vars (OPENROUTER_API_KEY).
.env
.env.*
*.key
secrets.*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# OS
.DS_Store

# Eval scratch
eval/_bad_manifest_tmp*.json

# Next.js site build artifacts (site/data/ is committed — it's the build input)
site/node_modules/
site/.next/
site/out/
site/next-env.d.ts
site/.vercel/
*.tsbuildinfo
